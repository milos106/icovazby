{
  "name": "ares-web",
  "version": "0.2.0",
  "private": true,
  "description": "Web application for Czech business registry due-diligence — search companies, run risk checks, map cross-company connections. Built on the public ARES API.",
  "license": "MIT",
  "author": "milos106 <max118@seznam.cz>",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src tests public"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1",
    "p-retry": "^6.2.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.10",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
