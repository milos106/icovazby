{
  "name": "icovazby",
  "version": "0.9.15",
  "private": true,
  "description": "Webová prověrka českých firem a jejich propojení — agreguje ARES, OR, RŽP, ADIS DPH, ISIR, ČNB JERRS, EU sankce a Hlídač státu do risk skóre + holding discovery + cross-company graph.",
  "license": "AGPL-3.0-or-later",
  "author": "milos106 <max118@seznam.cz>",
  "repository": "https://github.com/milos106/icovazby",
  "homepage": "https://github.com/milos106/icovazby",
  "bugs": "https://github.com/milos106/icovazby/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write src tests public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^12.10.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.2.1",
    "lru-cache": "^11.5.1",
    "marked": "^18.0.5",
    "nodemailer": "^8.0.10",
    "p-limit": "^7.3.0",
    "p-retry": "^6.2.0",
    "resend": "^6.12.4",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^8.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
