# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit your real tokens.
#
# Server
PORT=3000
HOST=127.0.0.1
LOG_LEVEL=info

# ARES upstream
ARES_RATE_PER_SECOND=5
ARES_TIMEOUT_MS=15000
ARES_RETRIES=3

# Hlídač státu API token (https://www.hlidacstatu.cz/api)
# Required for: public contracts (smlouvy), procurement (zakazky),
# beneficial owners (UBO), subsidies (dotace), politicians data.
# Without this token, those features show a "feature unavailable" notice.
# Atribution CC BY 3.0 is rendered automatically when this token is set.
HLIDAC_API_TOKEN=

# Rate limiting (per IP per minute)
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_HEAVY_PER_MIN=10   # holding/cross-persons endpoints
DD_CACHE_TTL_MS=86400000      # 24h cache pro /api/dd a /api/vr

# E-mail alerts (volitelné — pokud SMTP_HOST chybí, mailer jen loguje)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@icovaz.local
# PUBLIC_BASE_URL=https://icovaz.example.com  # pro verifikační odkazy
# ALERTS_CHECK_MIN=360                          # jak často kontroluje změny (min)
